{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "parkourone/job-cards",
	"version": "3.1.0",
	"title": "Job Cards",
	"category": "parkourone-about",
	"icon": "businessperson",
	"description": "Zeigt Stellenangebote aus dem Jobs CPT an. Versteckt sich automatisch wenn keine Jobs vorhanden sind.",
	"keywords": ["jobs", "stellen", "karriere", "bewerbung"],
	"textdomain": "parkourone",
	"editorScript": "file:./index.js",
	"viewScript": "file:./view.js",
	"style": "file:./style.css",
	"render": "file:./render.php",
	"attributes": {
		"headline": { "type": "string", "default": "Werde Teil unseres Teams" },
		"intro": { "type": "string", "default": "Wir bei ParkourONE sind ständig auf der Suche nach begeisterten und talentierten Menschen, die unser Team bereichern wollen." },
		"backgroundColor": { "type": "string", "default": "#f5f5f7" },
		"showFilter": { "type": "boolean", "default": true }
	},
	"supports": { "align": ["full", "wide"], "html": false, "anchor": true }
}
